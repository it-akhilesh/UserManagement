@model Login_Page.Models.StudentViewModel
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<h2>Student Logged In</h2>
<h3>Username: @ViewBag.Username</h3>
<h3>Role: @(ViewData["Role"] as string)</h3>

<h1>@(ViewData["Message"] as string)</h1>

@using (Html.BeginForm("Index", "Student", FormMethod.Post,
    new { enctype = "multipart/form-data" }))
{
    <div class="form-group">
        <div class="row align-items-center mb-3">
            @Html.LabelFor(model => model.Name, "Name", new { @class = "col-sm-2 col-form-label" })
            <div class="col-sm-9">
                @Html.TextBoxFor(model => model.Name, new { @class = "form-control", placeholder = "name@example.com", type = "text" })
                @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="row align-items-center mb-3">
            @Html.LabelFor(model => model.Address, "Address", new { @class = "col-sm-2 col-form-label" })
            <div class="col-sm-9">
                @Html.TextBoxFor(model => model.Address, new { @class = "form-control", placeholder = "Enter a Address", type = "text" })
                @Html.ValidationMessageFor(model => model.Address, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="row align-items-center mb-3">
            @Html.LabelFor(model => model.Country, "Country", new { @class = "col-sm-2 col-form-label" })
            <div class="col-sm-9">
                @Html.DropDownListFor(model => model.Country, Model.CountryList,
                    "-- Select Country --",
                    new { @class = "form-select" })
                @Html.ValidationMessageFor(model => model.Country, "", new { @class = "text-danger" })
            </div>
            
        </div>
        <div class="row align-items-center mb-3">
            @Html.LabelFor(model => model.State, "State", new { @class = "col-sm-2 col-form-label" })
            <div class="col-sm-9">
                @Html.DropDownListFor(model => model.State, Model.StateList,
                    "-- Select State --",
                    new { @class = "form-select" })
                @Html.ValidationMessageFor(model => model.State, "", new { @class = "text-danger" })
            </div>
            
        </div>
        <div class="row align-items-center mb-3">
            @Html.LabelFor(model => model.City, "City", new { @class = "col-sm-2 col-form-label" })
            <div class="col-sm-9">
                @Html.DropDownListFor(model => model.City, Model.CityList,
                    "-- Select City --",
                    new { @class = "form-select" })
                @Html.ValidationMessageFor(model => model.City, "", new { @class = "text-danger" })
            </div>
            
        </div>
        <div class="row align-items-center mb-3">
            @Html.LabelFor(model => model.PinCode, "PinCode", new { @class = "col-sm-2 col-form-label" })
            <div class="col-sm-9">
                @Html.TextBoxFor(model => model.PinCode, new { @class = "form-control", placeholder = "Enter a Pincode", type = "text" })
                @Html.ValidationMessageFor(model => model.PinCode, "", new { @class = "text-danger" })
            </div>
            
        </div>
        <div class="row align-items-center mb-3">
            @Html.LabelFor(model => model.MobileNo, "Mobile No", new { @class = "col-sm-2 col-form-label" })
            <div class="col-sm-9">
                @Html.TextBoxFor(model => model.MobileNo, new { @class = "form-control", placeholder = "Enter a Number", type = "text" })
                @Html.ValidationMessageFor(model => model.MobileNo, "", new { @class = "text-danger" })
            </div>
            
        </div>
        <div class="row align-items-center mb-3">
            @Html.LabelFor(model => model.Email, "Email", new { @class = "col-sm-2 col-form-label" })
            <div class="col-sm-9">
                @Html.TextBoxFor(model => model.Email, new { @class = "form-control", placeholder = "abc@gmail.com", type = "text" })
                @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
            </div>
            
        </div>
        <div class="row align-items-center mb-3">
            @Html.LabelFor(model => model.Photo, "Upload Photo", new { @class = "col-sm-2 col-form-label" })
            <div class="col-sm-9">
                @Html.TextBoxFor(model => model.Photo, new { @class = "form-control", placeholder = "Choose Photo", type = "file" })
                @Html.ValidationMessageFor(model => model.Photo, "", new { @class = "text-danger" })
            </div>
        </div>
        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" class="btn btn-primary mb-3" />
            </div>
        </div>

    </div>
}


